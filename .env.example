# ---- Server ----
PORT=4000

# ---- Google PageSpeed Insights ----
# Optional but strongly recommended. Without a key you share a tiny anonymous
# quota and will be rate-limited quickly. Get a free key:
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
# mobile | desktop
PAGESPEED_STRATEGY=mobile

# ---- Scheduled checks ----
# Cron expression for background checks. Default: every 1 hours.
CHECK_CRON=*/2 * * * *
# Run a full check once on startup (true/false)
CHECK_ON_START=true

# ---- Thresholds ----
# PageSpeed performance score (0-100): below WARN = amber, below FAIL = red
PAGESPEED_WARN=90
PAGESPEED_FAIL=50
# SSL certificate: warn when fewer than this many days remain
SSL_WARN_DAYS=14

# ---- Alerts: Slack (optional) ----
# Incoming webhook URL. Leave blank to disable.
SLACK_WEBHOOK_URL=

# ---- Alerts: Email (optional) ----
# Leave SMTP_HOST blank to disable email alerts.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Clickup Integration API Key
CLICKUP_API_TOKEN=

PORT=4000
PUBLIC_URL=
DATABASE_URL=
SESSION_SECRET=
ADMIN_EMAILS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=